# Files we don't want the OpenAPI generator to (re)create in
# knievel-ruby. Patterns follow .gitignore syntax.

# Other-CI scaffolding the Ruby template emits by default; we
# drive everything from knievel's GitHub Actions.
.travis.yml
.gitlab-ci.yml
git_push.sh

# Hand-written `Enumerable` wrapper layer + convenience client
# facade (Phase 4.10). Lives alongside the generated `*Api` /
# `models/*` classes and is hand-maintained. The generator
# doesn't have templates for these paths today, so the rules
# below are belt-and-suspenders against future generator
# versions that might.
lib/knievel/resources.rb
lib/knievel/resources/**
lib/knievel/client.rb
spec/resources/**
spec/client_spec.rb
