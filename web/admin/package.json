{
  "name": "@knievel/admin",
  "version": "0.0.0",
  "private": true,
  "description": "Knievel admin audit console (UI.md). Vite + React + TanStack + Mantine.",
  "type": "module",
  "scripts": {
    "routes": "tsr generate",
    "dev": "vite",
    "build": "pnpm routes && tsc -b && vite build && node scripts/check-base-path.mjs",
    "preview": "vite preview",
    "typecheck": "pnpm routes && tsc -b --noEmit",
    "lint": "pnpm routes && eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm routes && vitest",
    "test:e2e": "playwright test",
    "size": "pnpm build && size-limit"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@mantine/core": "^7.13.5",
    "@mantine/dropzone": "^7.13.5",
    "@mantine/form": "^7.13.5",
    "@mantine/hooks": "^7.13.5",
    "@mantine/notifications": "^7.13.5",
    "@tanstack/react-query": "^5.62.7",
    "@tanstack/react-router": "^1.95.1",
    "oidc-client-ts": "^3.1.0",
    "openapi-fetch": "^0.13.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.0",
    "react-oidc-context": "^3.2.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@axe-core/react": "^4.10.1",
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.49.1",
    "@size-limit/preset-app": "^11.1.6",
    "@tanstack/react-query-devtools": "^5.62.7",
    "@tanstack/router-cli": "^1.95.1",
    "@tanstack/router-devtools": "^1.95.1",
    "@tanstack/router-plugin": "^1.95.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "axe-core": "^4.10.2",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "happy-dom": "^15.11.7",
    "openapi-typescript": "^7.5.0",
    "postcss": "^8.4.49",
    "postcss-preset-mantine": "^1.17.0",
    "postcss-simple-vars": "^7.0.1",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^6.0.7",
    "vitest": "^3.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "size-limit": [
    {
      "name": "main bundle (gzip)",
      "path": "dist/assets/index-*.js",
      "limit": "180 KB",
      "gzip": true
    },
    {
      "name": "Mantine CSS (gzip)",
      "path": "dist/assets/index-*.css",
      "limit": "35 KB",
      "gzip": true
    }
  ]
}
